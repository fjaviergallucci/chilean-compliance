# Default: text files normalized to LF in the repo, OS-native on checkout
* text=auto

# Markdown / data files — explicit LF in the repo
*.md text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Binary files — never apply line-ending conversion. Must come LAST so the
# `binary` macro wins over the generic `* text=auto` rule above.
*.pdf binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
